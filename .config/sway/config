# See also:
# <https://wiki.archlinux.org/title/Sway>

include /etc/sway/config-vars.d/*

set $os Mod4
set $fn Mod4+Mod1
set $alt Mod1
set $altgr Mod5
set $menu rofi -show drun -show-icons

# Lifted from <https://gist.github.com/Cardoso1994/80641d652a4adcf6c8f718ebc3770ab9>
set $bg       #282828
set $fg       #d4be98
set $red      #ea6962
set $orange   #e78a4e
set $green    #a9b665
set $dgreen   #495605
set $blue     #7daea3
set $purple   #d3869b
set $aqua     #89b482

#       Gruvbox Theme   brdr        bg          text    indictr     chld_brdr
client.focused          $dgreen     $dgreen     $dgreen $green      $dgreen
client.focused_inactive $bg         $bg         $bg     $green      $green
client.unfocused        $bg         $bg         $bg     $bg         $bg
client.urgent           $red        $red        $bg     $red        $red
client.placeholder      $bg         $bg         $bg     $bg         $bg
client.background       $bg
output * bg $bg solid_color

default_border normal 1
# default_border pixel 1
default_floating_border normal 2
floating_modifier Mod4 normal
focus_wrapping no
font Overpass, Cascadia Mono NF, FontAwesome 2
gaps inner -1
gaps outer -1
hide_edge_borders smart
smart_borders off
smart_gaps off
title_align center
titlebar_border_thickness 0
titlebar_padding 0 0
# title_window_icon yes # cf <https://github.com/swaywm/sway/issues/4882>

include config.d/*
